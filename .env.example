# ============================================================
# Ananke LLM 配置模板
# 复制本文件为 .env 并填入你自己的值：  cp .env.example .env
# .env 已被 .gitignore 忽略，密钥不会进入 git。
# 所有字段均可选，留空即使用下方默认值。
# ============================================================

# ---- 运行模式 ----
# true  = 使用 Mock LLM（离线、无需密钥，秒级跑通迁移/激活逻辑，适合调试）
# false = 使用下方配置的真实 LLM
USE_MOCK_LLM=true

# ---- LLM provider 切换 ----
# 支持：openai / deepseek / openrouter / groq / ollama / gemini / openai-compatible
# 这些都走 OpenAI 兼容接口，仅靠 base_url + api_key + model 区分，无需改代码。
# Gemini 使用其官方 OpenAI 兼容接口，若不填 LLM_BASE_URL 会自动用默认值。
LLM_PROVIDER=openai-compatible

# 你的 API Key（必填，当 USE_MOCK_LLM=false 时）
LLM_API_KEY=

# 接口地址。留空则使用 provider 默认值：
#   gemini   -> 自动用 https://generativelanguage.googleapis.com/v1beta/openai/
#   openai   -> OpenAI 官方
#   deepseek -> https://api.deepseek.com/v1
#   openrouter-> https://openrouter.ai/api/v1
#   groq     -> https://api.groq.com/openai/v1
#   ollama   -> http://localhost:11434/v1
# 用 Gemini 时通常留空即可。
LLM_BASE_URL=

# 模型名。随服务商而定，例如：
#   gemini   : gemini-2.0-flash / gemini-2.5-flash / gemini-1.5-flash
#   deepseek : deepseek-chat
#   openrouter: openai/gpt-3.5-turbo 或 anthropic/claude-3-haiku 等
#   groq     : llama-3.3-70b-versatile
#   ollama   : llama3
LLM_MODEL=deepseek-chat

# 采样温度（记忆提取/重组判断建议接近 0 以稳定输出）
LLM_TEMPERATURE=0.0

# ---- 嵌入模型（可选）----
# 默认 all-MiniLM-L6-v2 为英文模型；中文场景建议换成 bge-small-zh / m3e / bge-m3
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- 实验组/对照组（可选）----
# persistence（默认，存续检验）= 外部验证权重高于内部激活
# frequency（对照组，频率驱动）= 仅按内部激活次数迁移
WORKING_PROMOTION_STRATEGY=persistence
